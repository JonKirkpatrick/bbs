<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Bbs.Client.App.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <ResourceDictionary>
      <StreamGeometry x:Key="CloseIcon">M 2,2 L 10,10 M 10,2 L 2,10</StreamGeometry>
      <StreamGeometry x:Key="ToggleTrack">M 10,0 L 10,0 A 10,10 0 0 1 20,10 L 20,30 A 10,10 0 0 1 0,30 L 0,10 A 10,10 0 0 1 10,0 Z</StreamGeometry>
      <StreamGeometry x:Key="ToggleKnob">M 10,3 A 7,7 0 1 1 10,17 A 7,7 0 1 1 10,3 Z</StreamGeometry>
    </ResourceDictionary>
    <Color x:Key="Palette.Bg">#f5f1e9</Color>
    <Color x:Key="Palette.Paper">#f5f7fa</Color>
    <Color x:Key="Palette.Ink">#1b1c1f</Color>
    <Color x:Key="Palette.Muted">#5d6068</Color>
    <Color x:Key="Palette.Line">#ddd0b8</Color>
    <Color x:Key="Palette.Brand">#cc5d22</Color>
    <Color x:Key="Palette.BrandSoft">#f5d3c0</Color>
    <Color x:Key="Palette.Accent">#0e7a6d</Color>
    <Color x:Key="Palette.AccentSoft">#c5ece6</Color>
    <Color x:Key="Palette.OceanSurface">#c8e3e5</Color> 
    <Color x:Key="Palette.OceanDeep">#a4bbbc</Color>   
    <LinearGradientBrush x:Key="Palette.OceanDepthBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Offset="0.0" Color="{StaticResource Palette.OceanSurface}" />
        <GradientStop Offset="1.0" Color="{StaticResource Palette.OceanDeep}" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="Palette.WindowBackgroundBrush" Color="{StaticResource Palette.Bg}" />
    <SolidColorBrush x:Key="Palette.WindowForegroundBrush" Color="{StaticResource Palette.Ink}" />
    <SolidColorBrush x:Key="Palette.TitleBarBackground" Color="#CCF5F7FA" />
    <SolidColorBrush x:Key="Palette.TitleBarBorder" Color="#10000000" /> 

    <SolidColorBrush x:Key="Palette.PanelBackgroundBrush" Color="{StaticResource Palette.Paper}" />
    <SolidColorBrush x:Key="Palette.HeaderBackgroundBrush" Color="{StaticResource Palette.Line}" />
    <SolidColorBrush x:Key="Palette.SummaryCardBackgroundBrush" Color="{StaticResource Palette.Paper}" />
    <SolidColorBrush x:Key="Palette.BorderBrush" Color="{StaticResource Palette.Line}" />

    <SolidColorBrush x:Key="Palette.BrandBrush" Color="{StaticResource Palette.Brand}" />
    <SolidColorBrush x:Key="Palette.AccentBrush" Color="{StaticResource Palette.Accent}" />
      
    <SolidColorBrush x:Key="Palette.ButtonBackgroundBrush" Color="{StaticResource Palette.Brand}" />
    <SolidColorBrush x:Key="Palette.ButtonForegroundBrush" Color="{StaticResource Palette.Paper}" />
    <SolidColorBrush x:Key="Palette.ButtonHoverBackgroundBrush" Color="#b8531d" />
    <SolidColorBrush x:Key="Palette.ButtonPressedBackgroundBrush" Color="#9f4919" />

    <SolidColorBrush x:Key="Palette.TextPrimaryBrush" Color="{StaticResource Palette.Ink}" />
    <SolidColorBrush x:Key="Palette.TextSecondaryBrush" Color="{StaticResource Palette.Muted}" />
    <SolidColorBrush x:Key="Palette.TextTertiaryBrush" Color="#7a7d85" />
        
    <SolidColorBrush x:Key="Palette.InputBackgroundBrush" Color="{StaticResource Palette.Paper}" />
    <SolidColorBrush x:Key="Palette.InputForegroundBrush" Color="{StaticResource Palette.Ink}" />
    <SolidColorBrush x:Key="Palette.InputFocusBorderBrush" Color="{StaticResource Palette.Brand}" />

    <SolidColorBrush x:Key="Palette.ListItemBackgroundBrush" Color="Transparent" />
    <SolidColorBrush x:Key="Palette.ListItemForegroundBrush" Color="{StaticResource Palette.Ink}" />
    <SolidColorBrush x:Key="Palette.ListItemHoverBackgroundBrush" Color="#f0e7d8" />
    <SolidColorBrush x:Key="Palette.ListItemSelectedBackgroundBrush" Color="Transparent" />
    <SolidColorBrush x:Key="Palette.ListItemSelectedBorderBrush" Color="{StaticResource Palette.AccentSoft}" />
    <SolidColorBrush x:Key="Palette.ListItemFocusBorderBrush" Color="{StaticResource Palette.Brand}" />
    <SolidColorBrush x:Key="Palette.CardHoverBackgroundBrush" Color="{StaticResource Palette.AccentSoft}" />
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <Style Selector="ScrollBar">
      <Setter Property="Transitions">
          <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
          </Transitions>
      </Setter>
  </Style>

  <Style Selector="ScrollBar /template/ Thumb">
      <Setter Property="Background" Value="#80808080" /> <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="ScrollViewer ScrollBar">
      <Setter Property="Opacity" Value="0" />
  </Style>

  <Style Selector="ScrollViewer:pointerover ScrollBar">
      <Setter Property="Opacity" Value="1" />
  </Style>
    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource Palette.OceanDepthBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource Palette.WindowForegroundBrush}" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource Palette.InputBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource Palette.InputForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Palette.BorderBrush}" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource Palette.InputFocusBorderBrush}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Background" Value="{DynamicResource Palette.ButtonBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource Palette.ButtonForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Palette.BorderBrush}" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource Palette.ButtonHoverBackgroundBrush}" />
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{DynamicResource Palette.ButtonPressedBackgroundBrush}" />
    </Style>

    <Style Selector="Button.panel-icon-toggle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.panel-icon-toggle:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.panel-icon-toggle:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Path.panel-icon">
      <Setter Property="Fill" Value="Transparent" />
      <Setter Property="Stroke" Value="{DynamicResource Palette.BrandBrush}" />
      <Setter Property="StrokeThickness" Value="1.4" />
      <Setter Property="StrokeJoin" Value="Round" />
      <Setter Property="StrokeLineCap" Value="Round" />
    </Style>
    <Style Selector="Button.panel-icon-toggle:pointerover Path.panel-icon">
      <Setter Property="StrokeThickness" Value="2.1" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource Palette.ListItemSelectedBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource Palette.ListItemForegroundBrush}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource Palette.ListItemSelectedBackgroundBrush}" />
    </Style>
    <Style Selector="ListBoxItem:focus-visible /template/ Border#ItemContainerChrome">
      <Setter Property="BorderBrush" Value="{DynamicResource Palette.ListItemFocusBorderBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
  </Application.Styles>
</Application>
