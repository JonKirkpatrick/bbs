<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Bbs.Client.App.Controls.SummaryCard"
             x:Name="CardRoot">
  <UserControl.Styles>
    <Style Selector="Border#CardBorder">
      <Setter Property="Background" Value="{Binding BackgroundBrush, ElementName=CardRoot}" />
    </Style>

    <Style Selector="Border#CardBorder:pointerover">
      <Setter Property="Background" Value="{DynamicResource Palette.CardHoverBackgroundBrush}" />
    </Style>
  </UserControl.Styles>

  <Border x:Name="CardBorder"
          Margin="0,0,0,8"
          Padding="10"
          CornerRadius="8"
          BorderThickness="1"
          BorderBrush="{Binding AccentBrush, ElementName=CardRoot}">
    
    <StackPanel Spacing="3">
      <TextBlock FontWeight="SemiBold" Text="{Binding Title, ElementName=CardRoot}" />
      <TextBlock FontSize="12" Text="{Binding Subtitle, ElementName=CardRoot}" />
      <TextBlock FontSize="11" Text="{Binding StatusText, ElementName=CardRoot}" />
    </StackPanel>
  </Border>
</UserControl>
