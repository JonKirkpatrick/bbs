<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Bbs.Client.App.Controls.SummaryCard"
             x:Name="CardRoot">
  <Border Margin="0,0,0,8"
          Padding="10"
          CornerRadius="8"
          Opacity="1"
          BorderThickness="1"
          BorderBrush="{Binding AccentBrush, ElementName=CardRoot}"
          Background="{Binding BackgroundBrush, ElementName=CardRoot}">
    <StackPanel Spacing="3">
      <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource Palette.TextPrimaryBrush}" Text="{Binding Title, ElementName=CardRoot}" />
      <TextBlock FontSize="12" Foreground="{DynamicResource Palette.TextSecondaryBrush}" Text="{Binding Subtitle, ElementName=CardRoot}" />
      <TextBlock FontSize="11" Foreground="{DynamicResource Palette.TextTertiaryBrush}" Text="{Binding StatusText, ElementName=CardRoot}" />
    </StackPanel>
  </Border>
</UserControl>
