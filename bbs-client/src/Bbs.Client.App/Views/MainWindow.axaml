<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Bbs.Client.App.ViewModels"
        xmlns:controls="using:Bbs.Client.App.Controls"
        x:Class="Bbs.Client.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1040"
        Height="720"
        MinWidth="980"
        MinHeight="600"
        x:Name="RootWindow"
        Icon ="/Assets/icons/bbs.ico"
        Title="{Binding CurrentTitleText}"
        >

      <Window.Resources>
            <ControlTheme x:Key="CardListBoxItemTheme" TargetType="ListBoxItem">
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0" />
                  <Setter Property="Background" Value="Transparent" />
                  <Setter Property="BorderBrush" Value="Transparent" />
                  <Setter Property="BorderThickness" Value="0" />
                  <Setter Property="IsTabStop" Value="True" />
                  <Setter Property="Template">
                        <ControlTemplate>
                              <Border x:Name="ItemContainerChrome"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      CornerRadius="6"
                                      Padding="{TemplateBinding Padding}">
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                              </Border>
                        </ControlTemplate>
                  </Setter>
            </ControlTheme>
      </Window.Resources>

      <Panel>
            <Image Source="/Assets/ui/watermark-emboss-512.png" 
                  Opacity="0.2" 
                  Stretch="None"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  IsHitTestVisible="False" />

      <Grid RowDefinitions="32,*" Margin="0,0,0,16">
            <Menu Grid.Row="0" 
                  Height="32" 
                  ZIndex="10"
                  VerticalAlignment="Center" 
                  HorizontalAlignment="Left"
                  Margin="10,0,0,0"
                  Background="Transparent">
                  <MenuItem Header="_File">
                        <MenuItem Header="_New Persona"/>
                        <MenuItem Header="_Load Persona"/>
                        <Separator/>
                        <MenuItem Header="_Exit" Command="{Binding $parent[Window].Close}"/>
                  </MenuItem>
                  <MenuItem Header="_Edit">
                        <MenuItem Header="_Preferences">
                              <MenuItem Header="_Developer View"
                                        ToggleType="CheckBox"
                                        IsChecked="{Binding IsDeveloperViewEnabled, Mode=TwoWay}" />
                        </MenuItem>
                        <MenuItem Header="_Configuration"/>
                  </MenuItem>
            </Menu>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding LeftPanelWidth}" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{Binding RightPanelWidth}" />
                  </Grid.ColumnDefinitions>

                  <Grid Grid.Column="0" Margin="0,0,6,0" ZIndex="0">
                        <Border Background="{DynamicResource Palette.PanelBackgroundBrush}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="0,5,5,0" BoxShadow="5 2 20 0 #40000000" ZIndex="0" />
                        <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto" ClipToBounds="True" ZIndex="1">
                              <Grid Margin="0,0,0,8">
                              <Button Classes="panel-icon-toggle" 
                                          HorizontalAlignment="Left" 
                                          Width="28" Height="28" Padding="6"
                                          Command="{Binding StartNewBotCommand}"
                                          ToolTip.Tip="New Bot"
                                          IsVisible="{Binding IsLeftPanelExpanded}">
                                    <Path Data="{StaticResource PlusIcon}"
                                          Classes="panel-icon"
                                          Width="12" Height="12"
                                          Stretch="Uniform" />
                              </Button>

                              <TextBlock Text="Bots" 
                                          IsVisible="{Binding IsLeftPanelExpanded}" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontSize="18" 
                                          FontWeight="SemiBold" />

                              <Button Classes="panel-icon-toggle" 
                                          HorizontalAlignment="Right" 
                                          Width="28" Height="28" Padding="4" 
                                          Command="{Binding ToggleLeftPanelCommand}">
                                    <Grid>
                                          <Path IsVisible="{Binding IsLeftPanelExpanded}"
                                                Data="{StaticResource LeftAngleIcon}"
                                                Classes="panel-icon"
                                                ToolTip.Tip="Collapse"
                                                Width="10" Height="14"
                                                Stretch="Uniform" />

                                          <Path IsVisible="{Binding IsLeftPanelCollapsed}"
                                                Data="{StaticResource RightAngleIcon}"
                                                Classes="panel-icon"
                                                ToolTip.Tip="Expand"
                                                Width="10" Height="14"
                                                Stretch="Uniform" />
                                    </Grid>
                              </Button>
                              </Grid>
                              <ListBox Grid.Row="2"
                                                       IsVisible="{Binding IsLeftPanelExpanded}"
                                                       Background="Transparent"
                                                       Margin="0,10,0,0"
                                                       BorderThickness="0"
                                                       ItemContainerTheme="{StaticResource CardListBoxItemTheme}"
                                                       ItemsSource="{Binding Bots}"
                                                       ClipToBounds="True"
                                                       SelectedItem="{Binding SelectedBot}">
                                    <ListBox.ItemTemplate>
      <DataTemplate>
            <Grid Margin="0,0,0,8">
                  <controls:SummaryCard Title="{Binding Name}"
                                        IsActive="{Binding $parent[ListBoxItem].IsSelected}"
                                        Subtitle="{Binding Summary}"
                                        StatusText="{Binding Status}"
                                        AccentBrush="{Binding AccentBrush}"
                                        BackgroundBrush="{Binding BackgroundBrush}" />

                  <StackPanel IsVisible="{Binding $parent[ListBoxItem].IsSelected}" 
                              Orientation="Horizontal" 
                              Spacing="6" 
                              Margin="0,0,10,10"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center">
                  <Button Command="{Binding DeployCommand}"
                        Content="Deploy" />
                  </StackPanel>
            </Grid>
      </DataTemplate>
</ListBox.ItemTemplate>
                              </ListBox>
                        </Grid>
                  </Grid>

                  <Grid Grid.Column="1" Margin="6,0" ZIndex="10">
                        <Border Background="{DynamicResource Palette.PanelCenterBackgroundBrush}" BorderBrush="{DynamicResource Palette.BorderBrush}" BorderThickness="0" CornerRadius="10" ZIndex="0" />
                        <Grid Margin="14" RowDefinitions="Auto,Auto,*" ZIndex="1">
                              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center" IsVisible="{Binding ShowVerboseWorkspace}">
                                    <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding WorkspaceTitle}" />
                                    <Button Grid.Column="1" 
                                          Classes="panel-icon-toggle" 
                                          Width="28" Height="28" 
                                          Padding="4" 
                                          ToolTip.Tip="Back to Home"
                                          Command="{Binding SetHomeContextCommand}">
                                          <Path Classes="panel-icon"
                                                Width="12"
                                                Height="12"
                                                Stretch="Uniform"
                                                Data="{StaticResource CloseIcon}" />
                                    </Button>
                              </Grid>
                                    <TextBlock Grid.Row="1" Margin="0,10,0,10" Opacity="1" TextWrapping="Wrap" Text="{Binding WorkspaceDescription}" IsVisible="{Binding ShowVerboseWorkspace}" />

                                    <Border Grid.Row="2"
                                          IsVisible="{Binding ShowVerboseWorkspace}"
                                          Background="{DynamicResource Palette.NestedPanelBackgroundBrush}"
                                          BorderBrush="{DynamicResource Palette.BorderBrush}"
                                          BorderThickness="0"
                                          CornerRadius="8"
                                          Padding="16">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="8">
                                          <Border IsVisible="{Binding ShowBotEditor}" Margin="0,6,0,0" Padding="12" BorderThickness="0" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="0" Background="{DynamicResource Palette.EditorCardBackgroundBrush}">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                                      <TextBlock FontSize="15" FontWeight="SemiBold" Text="Bot Registration / Edit" />

                                                      <StackPanel Grid.Row="1" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Bot Name" />
                                                            <TextBox Text="{Binding BotEditorName}" Watermark="Counter Bot" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="2" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Launch Path" />
                                                            <TextBox Text="{Binding BotEditorLaunchPath}" Watermark="/opt/bots/mybot.py" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="3" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Launch Args (space-separated)" />
                                                            <TextBox Text="{Binding BotEditorArgs}" Watermark="--mode ranked" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="4" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Metadata (k=v;k2=v2)" />
                                                            <TextBox Text="{Binding BotEditorMetadata}" Watermark="lang=python;tier=alpha" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="5" Margin="0,8,0,0" Orientation="Horizontal" Spacing="8">
                                                            <Button Command="{Binding SaveBotProfileCommand}" Content="Save Bot" />
                                                      </StackPanel>

                                                      <Border Grid.Row="6" Margin="0,8,0,0" Padding="10" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}">
                                                            <StackPanel Spacing="6">
                                                                  <TextBlock FontSize="13" FontWeight="SemiBold" Text="Active Sessions (Developer)" />
                                                                  <TextBlock IsVisible="{Binding ShowActiveBotSessionsEmpty}" FontSize="12" Text="No active runtime sessions for this bot." />

                                                                  <ItemsControl IsVisible="{Binding HasActiveBotSessions}" ItemsSource="{Binding ActiveBotSessions}">
                                                                        <ItemsControl.ItemTemplate>
                                                                              <DataTemplate x:DataType="vm:ActiveBotSessionItem">
                                                                                    <Border Padding="8" CornerRadius="6" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}">
                                                                                          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                                                                                                <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" Opacity="0.8" Text="Session" />
                                                                                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding SessionId}" />

                                                                                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,0,0" FontSize="12" Opacity="0.8" Text="Server" />
                                                                                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="8,4,0,0" FontSize="12" Text="{Binding ServerName}" />

                                                                                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4,0,0" FontSize="12" Opacity="0.8" Text="Owner" />
                                                                                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="8,4,0,0" FontSize="12" Text="{Binding OwnerTokenMasked}" />

                                                                                                <Grid Grid.Row="3" Grid.Column="1" Margin="8,8,0,0" ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto">
                                                                                                      <ComboBox Grid.Column="0"
                                                                                                                ItemsSource="{Binding ArenaOptions}"
                                                                                                                SelectedItem="{Binding SelectedArena}"
                                                                                                                DisplayMemberBinding="{Binding Label}" />
                                                                                                      <TextBox Grid.Column="1" Margin="8,0,0,0" Width="80" Text="{Binding JoinHandicapPercent}" Watermark="0" />
                                                                                                      <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding JoinCommand}" Content="JOIN" />
                                                                                                </Grid>

                                                                                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,8,0,0" Orientation="Horizontal" Spacing="8">
                                                                                                      <Button Command="{Binding LeaveCommand}" Content="LEAVE" />
                                                                                                      <Button Command="{Binding QuitCommand}" Content="QUIT" />
                                                                                                </StackPanel>
                                                                                          </Grid>
                                                                                    </Border>
                                                                              </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                  </ItemsControl>
                                                            </StackPanel>
                                                      </Border>

                                                      <TextBlock Grid.Row="7" Margin="0,6,0,0" FontSize="12" Opacity="1" Text="{Binding BotEditorMessage}" />
                                                </Grid>
                                          </Border>

                                          <Border IsVisible="{Binding ShowServerEditor}" Margin="0,6,0,0" Padding="12" BorderThickness="0" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="0" Background="{DynamicResource Palette.EditorCardBackgroundBrush}">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                                      <Border Grid.Row="4" Margin="0,8,0,0" Padding="10" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}">
                                                            <StackPanel Spacing="6">
                                                                  <TextBlock FontSize="13" FontWeight="SemiBold" Text="Plugin Catalog" />
                                                                  <TextBlock FontSize="12" Text="{Binding ServerCatalogStatus}" />
                                                                  <TextBlock IsVisible="{Binding IsServerDetailLoading}" FontSize="12" Text="Loading cached plugin catalog..." />
                                                                  <TextBlock IsVisible="{Binding ShowServerPluginCatalogEmpty}" FontSize="12" Text="No cached plugin entries." />
                                                                  <ItemsControl IsVisible="{Binding HasServerPluginCatalog}" ItemsSource="{Binding ServerPluginCatalogEntries}">
                                                                        <ItemsControl.ItemTemplate>
                                                                              <DataTemplate x:DataType="vm:ServerPluginCatalogItem">
                                                                                    <Grid ColumnDefinitions="2*,2*,*">
                                                                                          <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" />
                                                                                          <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding DisplayName}" />
                                                                                          <TextBlock Grid.Column="2" Margin="8,0,0,0" FontSize="12" Text="{Binding Version}" />
                                                                                    </Grid>
                                                                              </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                  </ItemsControl>
                                                            </StackPanel>
                                                      </Border>

                                                      <Border Grid.Row="5" Margin="0,8,0,0" Padding="10" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}">
                                                            <StackPanel Spacing="6">
                                                                  <TextBlock FontSize="13" FontWeight="SemiBold" Text="Server Access Metadata" />
                                                                  <TextBlock FontSize="12" Text="{Binding ServerAccessStatus}" TextWrapping="Wrap" />
                                                                  <TextBlock IsVisible="{Binding IsServerAccessLoading}" FontSize="12" Text="Refreshing server access metadata..." />

                                                                  <Grid ColumnDefinitions="Auto,*">
                                                                        <TextBlock FontSize="12" Opacity="1" Text="Owner token:" />
                                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding ServerAccessOwnerToken}" />
                                                                  </Grid>

                                                                  <Grid ColumnDefinitions="Auto,*">
                                                                        <TextBlock FontSize="12" Opacity="1" Text="Dashboard:" />
                                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding ServerAccessDashboardEndpoint}" TextWrapping="Wrap" />
                                                                  </Grid>
                                                            </StackPanel>
                                                      </Border>

                                                      <Border Grid.Row="6" Margin="0,8,0,0" Padding="10" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}">
                                                            <StackPanel Spacing="6">
                                                                  <TextBlock FontSize="13" FontWeight="SemiBold" Text="Owner-Token Actions" />
                                                                  <TextBlock IsVisible="{Binding ShowOwnerTokenActionsUnavailable}"
                                                                             FontSize="12"
                                                                             Text="Valid owner-token metadata is required to perform arena controls." />

                                                                  <StackPanel IsVisible="{Binding ShowOwnerTokenActions}" Spacing="6">
                                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Create Arena" />
                                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                                                              <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" VerticalAlignment="Center" Text="Plugin" />
                                                                              <ComboBox Grid.Row="0"
                                                                                        Grid.Column="1"
                                                                                        Margin="8,0,0,0"
                                                                                        ItemsSource="{Binding ServerPluginCatalogEntries}"
                                                                                        SelectedValueBinding="{Binding Name}"
                                                                                        SelectedValue="{Binding OwnerArenaSelectedPlugin}"
                                                                                        DisplayMemberBinding="{Binding DisplayName}" />

                                                                              <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" FontSize="12" VerticalAlignment="Center" Text="Args" />
                                                                              <TextBox Grid.Row="1" Grid.Column="1" Margin="8,6,0,0" Text="{Binding OwnerArenaArgs}" Watermark="key=value key2=value2" />

                                                                              <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" FontSize="12" VerticalAlignment="Center" Text="Time ms" />
                                                                              <TextBox Grid.Row="2" Grid.Column="1" Margin="8,6,0,0" Text="{Binding OwnerArenaTimeMs}" Watermark="default game value" />

                                                                              <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,0,0" FontSize="12" VerticalAlignment="Center" Text="Allow handicap" />
                                                                              <CheckBox Grid.Row="3" Grid.Column="1" Margin="8,6,0,0" IsChecked="{Binding OwnerArenaAllowHandicap}" />
                                                                        </Grid>

                                                                        <Button Command="{Binding CreateArenaCommand}" Content="Create Arena" />
                                                                  </StackPanel>

                                                                  <TextBlock FontSize="12" Text="{Binding OwnerTokenActionStatus}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                      </Border>

                                                      <TextBlock Grid.Row="7" Margin="0,10,0,0" FontSize="15" FontWeight="SemiBold" Text="Known Server Registration / Edit" />

                                                      <StackPanel Grid.Row="8" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Server Name" />
                                                            <TextBox Text="{Binding ServerEditorName}" Watermark="Local Stadium" />
                                                      </StackPanel>

                                                      <Grid Grid.Row="9" Margin="0,6,0,0" ColumnDefinitions="2*,*,Auto">
                                                            <StackPanel Grid.Column="0" Spacing="2">
                                                                  <TextBlock FontSize="12" Opacity="1" Text="Host" />
                                                                  <TextBox Text="{Binding ServerEditorHost}" Watermark="127.0.0.1" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="2">
                                                                  <TextBlock FontSize="12" Opacity="1" Text="Dashboard Port" />
                                                                  <TextBox Text="{Binding ServerEditorPort}" Watermark="3000" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" Margin="8,20,0,0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                                                                  <CheckBox IsChecked="{Binding ServerEditorUseTls}" />
                                                                  <TextBlock FontSize="12" Text="TLS" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                      </Grid>

                                                      <StackPanel Grid.Row="10" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Metadata (k=v;k2=v2)" />
                                                            <TextBox Text="{Binding ServerEditorMetadata}" Watermark="region=local;tier=alpha" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="11" Margin="0,8,0,0" Orientation="Horizontal" Spacing="8">
                                                            <Button Command="{Binding SaveServerProfileCommand}" Content="Save Server" />
                                                            <Button Command="{Binding StartNewServerCommand}" Content="New Server" />
                                                      </StackPanel>
                                                </Grid>
                                          </Border>

                                          <Border IsVisible="{Binding ShowServerEditor}" Margin="0,6,0,0" Padding="12" BorderThickness="0" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="0" Background="{DynamicResource Palette.EditorCardBackgroundBrush}">
                                                <StackPanel Spacing="6">
                                                      <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="Active Arenas" />
                                                            <Button Grid.Column="1" Command="{Binding RefreshServerArenasCommand}" Content="Refresh" />
                                                      </Grid>

                                                      <TextBlock FontSize="12" Text="{Binding ServerArenasStatus}" TextWrapping="Wrap" />
                                                      <TextBlock IsVisible="{Binding IsServerArenasLoading}" FontSize="12" Text="Loading active arenas..." />

                                                      <ItemsControl ItemsSource="{Binding ServerArenaEntries}">
                                                            <ItemsControl.ItemTemplate>
                                                                  <DataTemplate x:DataType="vm:ServerArenaItem">
                                                                        <Border Margin="0,4,0,0" Padding="8" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}">
                                                                              <Grid ColumnDefinitions="*,Auto">
                                                                                    <StackPanel Spacing="2">
                                                                                          <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding ArenaId, StringFormat=Arena #{0}}" />
                                                                                          <TextBlock FontSize="12" Text="{Binding Game}" />
                                                                                          <TextBlock FontSize="11" Text="{Binding Players}" />
                                                                                          <TextBlock FontSize="11" Text="{Binding Status, StringFormat=Status: {0}}" />
                                                                                          <TextBlock FontSize="11" Text="{Binding MoveCount, StringFormat=Moves: {0}}" />
                                                                                    </StackPanel>

                                                                                    <Button Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Command="{Binding WatchCommand}" Content="Watch" />
                                                                              </Grid>
                                                                        </Border>
                                                                  </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                      </ItemsControl>
                                                </StackPanel>
                                          </Border>

                                          <Border IsVisible="{Binding ShowArenaViewer}" Margin="0,6,0,0" Padding="12" BorderThickness="0" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="0" Background="{DynamicResource Palette.EditorCardBackgroundBrush}">
                                                <StackPanel Spacing="8">
                                                      <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="Live Arena Watch" />
                                                            <Button Grid.Column="1"
                                                                    IsVisible="{Binding ShowOpenArenaViewerButton}"
                                                                    Command="{Binding OpenArenaViewerInBrowserCommand}"
                                                                    Content="Open JS Viewer" />
                                                      </Grid>

                                                      <TextBlock FontSize="12" Text="{Binding ArenaViewerStatus}" TextWrapping="Wrap" />
                                                      <TextBlock FontSize="11" Text="{Binding ArenaViewerUrl}" TextWrapping="Wrap" />
                                                      <TextBlock FontSize="11" Text="{Binding ArenaViewerPluginEntryUrl}" TextWrapping="Wrap" />

                                                      <Border x:Name="ArenaViewerViewport"
                                                              BorderThickness="0"
                                                              BorderBrush="Transparent"
                                                              CornerRadius="0"
                                                              Background="Transparent"
                                                              MinHeight="360"
                                                              ClipToBounds="True">
                                                            <Grid ClipToBounds="True">
                                                                  <Border x:Name="ArenaEmbeddedViewerSurface"
                                                                          IsVisible="{Binding IsEmbeddedViewerSupported}"
                                                                          Background="#F6F7F8"
                                                                          CornerRadius="8"
                                                                          Padding="6"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Top"
                                                                          BoxShadow="0 2 8 0 #22000000">
                                                                        <ContentControl x:Name="ArenaEmbeddedViewerHost"
                                                                                        HorizontalAlignment="Center"
                                                                                        VerticalAlignment="Center" />
                                                                  </Border>
                                                                  <Border IsVisible="{Binding ShowEmbeddedViewerFallback}" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}" Padding="10">
                                                                        <TextBlock FontSize="12"
                                                                                   TextWrapping="Wrap"
                                                                                   Text="Embedded viewer is unavailable. Use the fallback raw-state panel or open the external JS viewer link." />
                                                                  </Border>
                                                            </Grid>
                                                      </Border>

                                                      <Expander Header="Raw Game State" IsExpanded="False">
                                                            <TextBox AcceptsReturn="True"
                                                                     IsReadOnly="True"
                                                                     MinHeight="220"
                                                                     TextWrapping="Wrap"
                                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                     Text="{Binding ArenaViewerRawState}" />
                                                      </Expander>

                                                      <Expander Header="Viewer Diagnostics" IsExpanded="False">
                                                            <TextBox AcceptsReturn="True"
                                                                     IsReadOnly="True"
                                                                     MinHeight="120"
                                                                     TextWrapping="Wrap"
                                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                     Text="{Binding ArenaViewerDiagnostics}" />
                                                      </Expander>
                                                </StackPanel>
                                          </Border>

                                          <TextBlock IsVisible="{Binding ShowServerEditor}"
                                                     Margin="0,6,0,0"
                                                     FontSize="12"
                                                     Opacity="1"
                                                     Text="{Binding ServerEditorMessage}" />
                                    </StackPanel>
                                    </ScrollViewer>
                              </Border>

                              <Border Grid.Row="2"
                                      IsVisible="{Binding ShowGraphicsFirstWorkspacePlaceholder}"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      CornerRadius="8" />
                        </Grid>
                  </Grid>

                  <Grid Grid.Column="2" Margin="6,0,0,0" ZIndex="0">
                        <Border Background="{DynamicResource Palette.PanelBackgroundBrush}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="5,0,0,5" BoxShadow="4 2 20 0 #40000000" ZIndex="0" />
                        <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto" ClipToBounds="True" ZIndex="1">
                              <Grid>
                                    <TextBlock IsVisible="{Binding IsRightPanelExpanded}" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Servers" />
                                    <Button Classes="panel-icon-toggle" HorizontalAlignment="Left" Width="28" Height="28" Padding="4" Command="{Binding ToggleRightPanelCommand}">
                                          <Grid>
                                                <Path IsVisible="{Binding IsRightPanelExpanded}"
                                                      Data="{StaticResource RightAngleIcon}"
                                                      Classes="panel-icon"
                                                      Width="10"
                                                      Height="14"
                                                      Stretch="Uniform" />

                                                <Path IsVisible="{Binding IsRightPanelCollapsed}"
                                                      Data="{StaticResource LeftAngleIcon}"
                                                      Classes="panel-icon"
                                                      Width="10"
                                                      Height="14"
                                                      Stretch="Uniform" />
                                          </Grid>
                                    </Button>
                              </Grid>
                              <ListBox Grid.Row="2"
                                                       IsVisible="{Binding IsRightPanelExpanded}"
                                                       Margin="0,10,0,0"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       ItemContainerTheme="{StaticResource CardListBoxItemTheme}"
                                                       ItemsSource="{Binding Servers}"
                                                       ClipToBounds="True"
                                                       SelectedItem="{Binding SelectedServer}">
                                    <ListBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:ServerSummaryItem">
                                                <controls:SummaryCard Title="{Binding Name}"
                                                                                                                  IsActive="{Binding $parent[ListBoxItem].IsSelected}"
                                                                                                                  Subtitle="{Binding Endpoint}"
                                                                                                                  StatusText="{Binding Status}"
                                                                                                                  AccentBrush="{Binding AccentBrush}"
                                                                                                                  BackgroundBrush="{Binding BackgroundBrush}" />
                                          </DataTemplate>
                                    </ListBox.ItemTemplate>
                              </ListBox>

                              <Grid Grid.Row="3"
                                    IsVisible="{Binding IsRightPanelExpanded}"
                                    Margin="0,8,0,0"
                                    ColumnDefinitions="*,*">
                                    <Button Grid.Column="0"
                                            Margin="0,0,4,0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding StartNewServerCommand}"
                                            Content="New Server" />
                                    <Button Grid.Column="1"
                                            Margin="4,0,0,0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding ReprobeServersCommand}"
                                            Content="Reprobe" />
                              </Grid>

                        </Grid>
                  </Grid>
            </Grid>
  </Grid>
  </Panel>
</Window>
