<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:vm="using:Bbs.Client.App.ViewModels"
      xmlns:controls="using:Bbs.Client.App.Controls"
        x:Class="Bbs.Client.App.Views.MainWindow"
                        x:DataType="vm:MainWindowViewModel"
        Width="1040"
        Height="720"
                        MinWidth="980"
        MinHeight="600"
        Background="{DynamicResource Palette.WindowBackgroundBrush}"
        Foreground="{DynamicResource Palette.WindowForegroundBrush}"
      x:Name="RootWindow"
        Title="{Binding WindowTitle}"
        mc:Ignorable="d">
      <Window.Resources>
            <ControlTheme x:Key="CardListBoxItemTheme" TargetType="ListBoxItem">
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0" />
                  <Setter Property="Background" Value="Transparent" />
                  <Setter Property="BorderBrush" Value="Transparent" />
                  <Setter Property="BorderThickness" Value="0" />
                  <Setter Property="IsTabStop" Value="True" />
                  <Setter Property="Template">
                        <ControlTemplate>
                              <Border x:Name="ItemContainerChrome"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      CornerRadius="6"
                                      Padding="{TemplateBinding Padding}">
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                              </Border>
                        </ControlTemplate>
                  </Setter>
            </ControlTheme>
      </Window.Resources>
      <Grid RowDefinitions="Auto,*" Margin="16">
            <Border CornerRadius="10" Padding="14" Background="{DynamicResource Palette.HeaderBackgroundBrush}" BorderBrush="{DynamicResource Palette.BorderBrush}" BorderThickness="1">
                  <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Spacing="2">
                              <TextBlock FontSize="22" FontWeight="Bold" Text="Build-a-Bot Stadium" />
                              <TextBlock FontSize="12" Opacity="1" Text="Unified workspace shell" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Command="{Binding EmitSampleLogCommand}"
                                                Content="Log workspace event" />
                  </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding LeftPanelWidth}" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{Binding RightPanelWidth}" />
                  </Grid.ColumnDefinitions>

                  <Grid Grid.Column="0" Margin="0,0,6,0" ZIndex="0">
                        <Border Background="{DynamicResource Palette.PanelBackgroundBrush}" BorderBrush="{DynamicResource Palette.BorderBrush}" BorderThickness="1" CornerRadius="10" ZIndex="0" />
                        <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto" ClipToBounds="True" ZIndex="1">
                              <Grid>
                                    <TextBlock IsVisible="{Binding IsLeftPanelExpanded}" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Bots" />
                                    <Button Classes="panel-icon-toggle" HorizontalAlignment="Right" Width="28" Height="28" Padding="4" Command="{Binding ToggleLeftPanelCommand}">
                                          <Grid>
                                                <Path IsVisible="{Binding IsLeftPanelExpanded}"
                                                      Classes="panel-icon"
                                                      Width="10"
                                                      Height="14"
                                                      Stretch="Uniform"
                                                      Data="M 7.238105,0.18057061 C 6.923615,0.18057061 6.450145,0.45014061 6.180565,0.76192061 L 0.180525,7.2619006 C -0.060175,7.5428006 -0.060175,7.9572006 0.180525,8.2381006 L 6.180565,15.238101 C 6.450145,15.552601 6.923615,15.589001 7.238105,15.319501 C 7.552595,15.049901 7.589025,14.576401 7.319455,14.261901 L 1.737825,7.7500006 L 7.319455,1.2381106 C 7.589025,0.92361061 7.552595,0.45014061 7.238105,0.18057061 Z" />
                                                <Path IsVisible="{Binding IsLeftPanelCollapsed}"
                                                      Classes="panel-icon"
                                                      Width="10"
                                                      Height="14"
                                                      Stretch="Uniform"
                                                      Data="M 0.26192061,0.18057061 C 0.57641061,-0.08899939 1.0498906,-0.05256939 1.3194606,0.26192061 L 7.3195006,7.2619006 C 7.5602006,7.5428006 7.5602006,7.9572006 7.3195006,8.2381006 L 1.3194606,15.238101 C 1.0498906,15.552601 0.57641061,15.589001 0.26192061,15.319501 C -0.05256939,15.049901 -0.08899939,14.576401 0.18057061,14.261901 L 5.7622006,7.7500006 L 0.18057061,1.2381106 C -0.08899939,0.92361061 -0.05256939,0.45014061 0.26192061,0.18057061 Z" />
                                          </Grid>
                                    </Button>
                              </Grid>
                              <TextBlock Grid.Row="1" IsVisible="{Binding IsLeftPanelExpanded}" Margin="0,8,0,8" Opacity="1" Text="Registered and local to this client" />

                              <ListBox Grid.Row="2"
                                                       IsVisible="{Binding IsLeftPanelExpanded}"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       ItemContainerTheme="{StaticResource CardListBoxItemTheme}"
                                                       ItemsSource="{Binding Bots}"
                                                       ClipToBounds="True"
                                                       SelectedItem="{Binding SelectedBot}">
                                    <ListBox.ItemTemplate>
                                          <DataTemplate>
                                                <StackPanel Spacing="0">
                                                      <controls:SummaryCard Title="{Binding Name}"
                                                                            IsActive="{Binding $parent[ListBoxItem].IsSelected}"
                                                                            Subtitle="{Binding Summary}"
                                                                            StatusText="{Binding Status}"
                                                                            AccentBrush="{Binding AccentBrush}"
                                                                            BackgroundBrush="{Binding BackgroundBrush}" />
                                                      <StackPanel IsVisible="{Binding $parent[ListBoxItem].IsSelected}" Orientation="Horizontal" Spacing="6" Margin="0,-4,0,8">
                                                                <Button IsVisible="{Binding CanArm}"
                                                                      Command="{Binding ArmCommand}"
                                                                    Content="Arm" />
                                                                <Button IsVisible="{Binding CanDisarm}"
                                                                      Command="{Binding DisarmCommand}"
                                                                    Content="Disarm" />
                                                                <Button Command="{Binding DeployCommand}"
                                                                    Content="Deploy" />
                                                      </StackPanel>
                                                </StackPanel>
                                          </DataTemplate>
                                    </ListBox.ItemTemplate>
                              </ListBox>

                              <Button Grid.Row="3"
                                      IsVisible="{Binding IsLeftPanelExpanded}"
                                      Margin="0,8,0,0"
                                      HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Center"
                                      Command="{Binding StartNewBotCommand}"
                                      Content="New Bot" />

                        </Grid>
                  </Grid>

                  <Grid Grid.Column="1" Margin="6,0" ZIndex="10">
                        <Border Background="{DynamicResource Palette.PanelCenterBackgroundBrush}" BorderBrush="{DynamicResource Palette.BorderBrush}" BorderThickness="1" CornerRadius="10" ZIndex="0" />
                        <Grid Margin="14" RowDefinitions="Auto,Auto,*" ZIndex="1">
                              <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                    <TextBlock FontSize="20" FontWeight="Bold" Text="ActivitySpace" />
                                    <Button Grid.Column="1" Classes="panel-icon-toggle" Width="28" Height="28" Padding="4" Command="{Binding SetHomeContextCommand}">
                                          <Path Classes="panel-icon"
                                                Width="12"
                                                Height="12"
                                                Stretch="Uniform"
                                                Data="M 2,2 L 10,10 M 10,2 L 2,10" />
                                    </Button>
                              </Grid>
                              <TextBlock Grid.Row="1" Margin="0,10,0,10" Opacity="1" Text="{Binding CurrentContextLabel}" />

                              <Border Grid.Row="2" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}" BorderBrush="{DynamicResource Palette.BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel Spacing="8">
                                          <TextBlock FontSize="17" FontWeight="SemiBold" Text="{Binding WorkspaceTitle}" />
                                          <TextBlock TextWrapping="Wrap" Text="{Binding WorkspaceDescription}" />

                                          <Border IsVisible="{Binding ShowBotEditor}" Margin="0,6,0,0" Padding="12" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.EditorCardBackgroundBrush}">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                                      <TextBlock FontSize="15" FontWeight="SemiBold" Text="Bot Registration / Edit" />

                                                      <StackPanel Grid.Row="1" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Bot Name" />
                                                            <TextBox Text="{Binding BotEditorName}" Watermark="Counter Bot" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="2" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Launch Path" />
                                                            <TextBox Text="{Binding BotEditorLaunchPath}" Watermark="/opt/bots/mybot.py" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="3" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Launch Args (space-separated)" />
                                                            <TextBox Text="{Binding BotEditorArgs}" Watermark="--mode ranked" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="4" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Metadata (k=v;k2=v2)" />
                                                            <TextBox Text="{Binding BotEditorMetadata}" Watermark="lang=python;tier=alpha" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="5" Margin="0,8,0,0" Orientation="Horizontal" Spacing="8">
                                                            <Button Command="{Binding SaveBotProfileCommand}" Content="Save Bot" />
                                                      </StackPanel>

                                                      <TextBlock Grid.Row="6" Margin="0,6,0,0" FontSize="12" Opacity="1" Text="{Binding BotEditorMessage}" />
                                                </Grid>
                                          </Border>

                                          <Border IsVisible="{Binding ShowServerEditor}" Margin="0,6,0,0" Padding="12" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.EditorCardBackgroundBrush}">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                                      <TextBlock FontSize="15" FontWeight="SemiBold" Text="Server Detail" />

                                                      <Grid Grid.Row="1" Margin="0,6,0,0" ColumnDefinitions="Auto,*">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Endpoint:" />
                                                            <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding ServerDetailEndpoint}" />
                                                      </Grid>

                                                      <Grid Grid.Row="2" Margin="0,2,0,0" ColumnDefinitions="Auto,*">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Probe:" />
                                                            <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding ServerDetailProbeStatus}" />
                                                      </Grid>

                                                      <Border Grid.Row="3" Margin="0,8,0,0" Padding="10" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}">
                                                            <StackPanel Spacing="6">
                                                                  <TextBlock FontSize="13" FontWeight="SemiBold" Text="Metadata" />
                                                                  <TextBlock IsVisible="{Binding ShowServerMetadataEmpty}" FontSize="12" Text="No metadata available." />
                                                                  <ItemsControl IsVisible="{Binding HasServerMetadata}" ItemsSource="{Binding ServerMetadataEntries}">
                                                                        <ItemsControl.ItemTemplate>
                                                                              <DataTemplate x:DataType="vm:ServerMetadataEntryItem">
                                                                                    <Grid ColumnDefinitions="Auto,*">
                                                                                          <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Key}" />
                                                                                          <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding Value}" TextWrapping="Wrap" />
                                                                                    </Grid>
                                                                              </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                  </ItemsControl>
                                                            </StackPanel>
                                                      </Border>

                                                      <Border Grid.Row="4" Margin="0,8,0,0" Padding="10" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}">
                                                            <StackPanel Spacing="6">
                                                                  <TextBlock FontSize="13" FontWeight="SemiBold" Text="Plugin Catalog" />
                                                                  <TextBlock FontSize="12" Text="{Binding ServerCatalogStatus}" />
                                                                  <TextBlock IsVisible="{Binding IsServerDetailLoading}" FontSize="12" Text="Loading cached plugin catalog..." />
                                                                  <TextBlock IsVisible="{Binding ShowServerPluginCatalogEmpty}" FontSize="12" Text="No cached plugin entries." />
                                                                  <ItemsControl IsVisible="{Binding HasServerPluginCatalog}" ItemsSource="{Binding ServerPluginCatalogEntries}">
                                                                        <ItemsControl.ItemTemplate>
                                                                              <DataTemplate x:DataType="vm:ServerPluginCatalogItem">
                                                                                    <Grid ColumnDefinitions="2*,2*,*">
                                                                                          <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" />
                                                                                          <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding DisplayName}" />
                                                                                          <TextBlock Grid.Column="2" Margin="8,0,0,0" FontSize="12" Text="{Binding Version}" />
                                                                                    </Grid>
                                                                              </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                  </ItemsControl>
                                                            </StackPanel>
                                                      </Border>

                                                      <Border Grid.Row="5" Margin="0,8,0,0" Padding="10" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}">
                                                            <StackPanel Spacing="6">
                                                                  <Grid ColumnDefinitions="*,Auto">
                                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="Server Access Metadata" />
                                                                        <Button Grid.Column="1"
                                                                                Command="{Binding RefreshServerAccessCommand}"
                                                                                HorizontalAlignment="Right"
                                                                                Content="Refresh" />
                                                                  </Grid>

                                                                  <TextBlock FontSize="12" Text="{Binding ServerAccessStatus}" TextWrapping="Wrap" />
                                                                  <TextBlock IsVisible="{Binding IsServerAccessLoading}" FontSize="12" Text="Refreshing server access metadata..." />

                                                                  <Grid ColumnDefinitions="Auto,*">
                                                                        <TextBlock FontSize="12" Opacity="1" Text="Owner token:" />
                                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding ServerAccessOwnerToken}" />
                                                                  </Grid>

                                                                  <Grid ColumnDefinitions="Auto,*">
                                                                        <TextBlock FontSize="12" Opacity="1" Text="Dashboard:" />
                                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="12" Text="{Binding ServerAccessDashboardEndpoint}" TextWrapping="Wrap" />
                                                                  </Grid>
                                                            </StackPanel>
                                                      </Border>

                                                      <Border Grid.Row="6" Margin="0,8,0,0" Padding="10" BorderThickness="1" BorderBrush="{DynamicResource Palette.BorderBrush}" CornerRadius="6" Background="{DynamicResource Palette.NestedPanelBackgroundBrush}">
                                                            <StackPanel Spacing="6">
                                                                  <TextBlock FontSize="13" FontWeight="SemiBold" Text="Owner-Token Actions" />
                                                                  <TextBlock IsVisible="{Binding ShowOwnerTokenActionsUnavailable}"
                                                                             FontSize="12"
                                                                             Text="Valid owner-token metadata is required to perform arena controls." />

                                                                  <StackPanel IsVisible="{Binding ShowOwnerTokenActions}" Spacing="6">
                                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Create Arena" />
                                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                                                                              <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" VerticalAlignment="Center" Text="Plugin" />
                                                                              <ComboBox Grid.Row="0"
                                                                                        Grid.Column="1"
                                                                                        ItemsSource="{Binding ServerPluginCatalogEntries}"
                                                                                        SelectedValueBinding="{Binding Name}"
                                                                                        SelectedValue="{Binding OwnerArenaSelectedPlugin}"
                                                                                        DisplayMemberBinding="{Binding DisplayName}" />

                                                                              <TextBlock Grid.Row="1" Grid.Column="0" FontSize="12" VerticalAlignment="Center" Text="Args" />
                                                                              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OwnerArenaArgs}" Watermark="key=value key2=value2" />

                                                                              <TextBlock Grid.Row="2" Grid.Column="0" FontSize="12" VerticalAlignment="Center" Text="Time ms" />
                                                                              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OwnerArenaTimeMs}" Watermark="default game value" />

                                                                              <TextBlock Grid.Row="3" Grid.Column="0" FontSize="12" VerticalAlignment="Center" Text="Allow handicap" />
                                                                              <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding OwnerArenaAllowHandicap}" />
                                                                        </Grid>

                                                                        <Button Command="{Binding CreateArenaStubCommand}" Content="Create Arena" />

                                                                        <TextBlock Margin="0,4,0,0" FontSize="12" FontWeight="SemiBold" Text="Join Arena" />
                                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                                                                              <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" VerticalAlignment="Center" Text="Arena ID" />
                                                                              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OwnerJoinArenaId}" Watermark="1" />

                                                                              <TextBlock Grid.Row="1" Grid.Column="0" FontSize="12" VerticalAlignment="Center" Text="Handicap %" />
                                                                              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OwnerJoinHandicapPercent}" Watermark="0" />
                                                                        </Grid>

                                                                        <Button Command="{Binding JoinArenaStubCommand}" Content="Join Arena" />
                                                                  </StackPanel>

                                                                  <TextBlock FontSize="12" Text="{Binding OwnerTokenActionStatus}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                      </Border>

                                                      <TextBlock Grid.Row="7" Margin="0,10,0,0" FontSize="15" FontWeight="SemiBold" Text="Known Server Registration / Edit" />

                                                      <StackPanel Grid.Row="8" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Server Name" />
                                                            <TextBox Text="{Binding ServerEditorName}" Watermark="Local Stadium" />
                                                      </StackPanel>

                                                      <Grid Grid.Row="9" Margin="0,6,0,0" ColumnDefinitions="2*,*,Auto">
                                                            <StackPanel Grid.Column="0" Spacing="2">
                                                                  <TextBlock FontSize="12" Opacity="1" Text="Host" />
                                                                  <TextBox Text="{Binding ServerEditorHost}" Watermark="127.0.0.1" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="2">
                                                                  <TextBlock FontSize="12" Opacity="1" Text="Dashboard Port" />
                                                                  <TextBox Text="{Binding ServerEditorPort}" Watermark="3000" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" Margin="8,20,0,0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                                                                  <CheckBox IsChecked="{Binding ServerEditorUseTls}" />
                                                                  <TextBlock FontSize="12" Text="TLS" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                      </Grid>

                                                      <StackPanel Grid.Row="10" Margin="0,6,0,0" Spacing="2">
                                                            <TextBlock FontSize="12" Opacity="1" Text="Metadata (k=v;k2=v2)" />
                                                            <TextBox Text="{Binding ServerEditorMetadata}" Watermark="region=local;tier=alpha" />
                                                      </StackPanel>

                                                      <StackPanel Grid.Row="11" Margin="0,8,0,0" Orientation="Horizontal" Spacing="8">
                                                            <Button Command="{Binding SaveServerProfileCommand}" Content="Save Server" />
                                                            <Button Command="{Binding StartNewServerCommand}" Content="New Server" />
                                                      </StackPanel>
                                                </Grid>
                                          </Border>

                                          <TextBlock IsVisible="{Binding ShowServerEditor}"
                                                     Margin="0,6,0,0"
                                                     FontSize="12"
                                                     Opacity="1"
                                                     Text="{Binding ServerEditorMessage}" />
                                    </StackPanel>
                              </Border>
                        </Grid>
                  </Grid>

                  <Grid Grid.Column="2" Margin="6,0,0,0" ZIndex="0">
                        <Border Background="{DynamicResource Palette.PanelBackgroundBrush}" BorderBrush="{DynamicResource Palette.BorderBrush}" BorderThickness="1" CornerRadius="10" ZIndex="0" />
                        <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto" ClipToBounds="True" ZIndex="1">
                              <Grid>
                                    <TextBlock IsVisible="{Binding IsRightPanelExpanded}" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Servers" />
                                    <Button Classes="panel-icon-toggle" HorizontalAlignment="Left" Width="28" Height="28" Padding="4" Command="{Binding ToggleRightPanelCommand}">
                                          <Grid>
                                                <Path IsVisible="{Binding IsRightPanelExpanded}"
                                                      Classes="panel-icon"
                                                      Width="10"
                                                      Height="14"
                                                      Stretch="Uniform"
                                                      Data="M 0.26192061,0.18057061 C 0.57641061,-0.08899939 1.0498906,-0.05256939 1.3194606,0.26192061 L 7.3195006,7.2619006 C 7.5602006,7.5428006 7.5602006,7.9572006 7.3195006,8.2381006 L 1.3194606,15.238101 C 1.0498906,15.552601 0.57641061,15.589001 0.26192061,15.319501 C -0.05256939,15.049901 -0.08899939,14.576401 0.18057061,14.261901 L 5.7622006,7.7500006 L 0.18057061,1.2381106 C -0.08899939,0.92361061 -0.05256939,0.45014061 0.26192061,0.18057061 Z" />
                                                <Path IsVisible="{Binding IsRightPanelCollapsed}"
                                                      Classes="panel-icon"
                                                      Width="10"
                                                      Height="14"
                                                      Stretch="Uniform"
                                                      Data="M 7.238105,0.18057061 C 6.923615,0.18057061 6.450145,0.45014061 6.180565,0.76192061 L 0.180525,7.2619006 C -0.060175,7.5428006 -0.060175,7.9572006 0.180525,8.2381006 L 6.180565,15.238101 C 6.450145,15.552601 6.923615,15.589001 7.238105,15.319501 C 7.552595,15.049901 7.589025,14.576401 7.319455,14.261901 L 1.737825,7.7500006 L 7.319455,1.2381106 C 7.589025,0.92361061 7.552595,0.45014061 7.238105,0.18057061 Z" />
                                          </Grid>
                                    </Button>
                              </Grid>
                              <TextBlock Grid.Row="1" IsVisible="{Binding IsRightPanelExpanded}" Margin="0,8,0,8" Opacity="1" Text="Known server endpoints and status" />

                              <ListBox Grid.Row="2"
                                                       IsVisible="{Binding IsRightPanelExpanded}"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       ItemContainerTheme="{StaticResource CardListBoxItemTheme}"
                                                       ItemsSource="{Binding Servers}"
                                                       ClipToBounds="True"
                                                       SelectedItem="{Binding SelectedServer}">
                                    <ListBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:ServerSummaryItem">
                                                <controls:SummaryCard Title="{Binding Name}"
                                                                                                                  IsActive="{Binding $parent[ListBoxItem].IsSelected}"
                                                                                                                  Subtitle="{Binding Endpoint}"
                                                                                                                  StatusText="{Binding Status}"
                                                                                                                  AccentBrush="{Binding AccentBrush}"
                                                                                                                  BackgroundBrush="{Binding BackgroundBrush}" />
                                          </DataTemplate>
                                    </ListBox.ItemTemplate>
                              </ListBox>

                              <Grid Grid.Row="3"
                                    IsVisible="{Binding IsRightPanelExpanded}"
                                    Margin="0,8,0,0"
                                    ColumnDefinitions="*,*">
                                    <Button Grid.Column="0"
                                            Margin="0,0,4,0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding StartNewServerCommand}"
                                            Content="New Server" />
                                    <Button Grid.Column="1"
                                            Margin="4,0,0,0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding ReprobeServersCommand}"
                                            Content="Reprobe" />
                              </Grid>

                        </Grid>
                  </Grid>
            </Grid>
  </Grid>
</Window>
