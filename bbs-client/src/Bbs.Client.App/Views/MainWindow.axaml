<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:vm="using:Bbs.Client.App.ViewModels"
      xmlns:controls="using:Bbs.Client.App.Controls"
        x:Class="Bbs.Client.App.Views.MainWindow"
                        x:DataType="vm:MainWindowViewModel"
        Width="1040"
        Height="720"
                        MinWidth="980"
        MinHeight="600"
        Title="{Binding WindowTitle}"
        mc:Ignorable="d">
      <Grid RowDefinitions="Auto,*" Margin="16">
            <Border CornerRadius="10" Padding="14" Background="#173142" BorderBrush="#2D5A74" BorderThickness="1">
                  <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Spacing="2">
                              <TextBlock FontSize="22" FontWeight="Bold" Text="Build-a-Bot Stadium" />
                              <TextBlock FontSize="12" Opacity="0.85" Text="Unified workspace shell" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Command="{Binding EmitSampleLogCommand}"
                                                Content="Log workspace event" />
                  </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding LeftPanelWidth}" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{Binding RightPanelWidth}" />
                  </Grid.ColumnDefinitions>

                  <Border Grid.Column="0" Margin="0,0,6,0" Background="#101E2A" BorderBrush="#2A4358" BorderThickness="1" CornerRadius="10" Padding="12">
                        <Grid RowDefinitions="Auto,Auto,*">
                              <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Bots" />
                                    <Button Grid.Column="1" FontSize="11" Command="{Binding ToggleLeftPanelCommand}" Content="{Binding LeftPanelToggleText}" />
                              </Grid>
                              <TextBlock Grid.Row="1" Margin="0,8,0,8" Opacity="0.78" Text="Registered and local to this client" />

                              <ListBox Grid.Row="2"
                                                       IsVisible="{Binding IsLeftPanelExpanded}"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       ItemsSource="{Binding Bots}"
                                                       SelectedItem="{Binding SelectedBot}">
                                    <ListBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:BotSummaryItem">
                                                <controls:SummaryCard Title="{Binding Name}"
                                                                                                                  Subtitle="{Binding Summary}"
                                                                                                                  StatusText="{Binding Status}"
                                                                                                                  AccentBrush="#365875"
                                                                                                                  BackgroundBrush="#152A3A" />
                                          </DataTemplate>
                                    </ListBox.ItemTemplate>
                              </ListBox>

                        </Grid>
                  </Border>

                  <Border Grid.Column="1" Margin="6,0" Background="#102B2B" BorderBrush="#2E5F57" BorderThickness="1" CornerRadius="10" Padding="14">
                        <Grid RowDefinitions="Auto,Auto,Auto,*">
                              <TextBlock FontSize="20" FontWeight="Bold" Text="Activity Workspace" />
                              <TextBlock Grid.Row="1" Margin="0,10,0,10" Opacity="0.8" Text="Center context host for bot/server workflows" />

                              <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                                    <Button Command="{Binding SetHomeContextCommand}" Content="Home" />
                                    <Button Command="{Binding SetBotContextCommand}" Content="Bot Context" />
                                    <Button Command="{Binding SetServerContextCommand}" Content="Server Context" />
                                    <TextBlock VerticalAlignment="Center" Opacity="0.75" Text="{Binding CurrentContextLabel}" />
                              </StackPanel>

                              <Border Grid.Row="3" Background="#163939" BorderBrush="#357170" BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel Spacing="8">
                                          <TextBlock FontSize="17" FontWeight="SemiBold" Text="{Binding WorkspaceTitle}" />
                                          <TextBlock TextWrapping="Wrap" Text="{Binding WorkspaceDescription}" />
                                          <TextBlock FontSize="12" Opacity="0.75" Text="Sprint 2 PR1 delivers the unified layout shell. Context routing and collapsible behavior land in PR2." />
                                    </StackPanel>
                              </Border>
                        </Grid>
                  </Border>

                  <Border Grid.Column="2" Margin="6,0,0,0" Background="#261E14" BorderBrush="#5F4A2E" BorderThickness="1" CornerRadius="10" Padding="12">
                        <Grid RowDefinitions="Auto,Auto,*">
                              <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Servers" />
                                    <Button Grid.Column="1" FontSize="11" Command="{Binding ToggleRightPanelCommand}" Content="{Binding RightPanelToggleText}" />
                              </Grid>
                              <TextBlock Grid.Row="1" Margin="0,8,0,8" Opacity="0.78" Text="Known server endpoints and status" />

                              <ListBox Grid.Row="2"
                                                       IsVisible="{Binding IsRightPanelExpanded}"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       ItemsSource="{Binding Servers}"
                                                       SelectedItem="{Binding SelectedServer}">
                                    <ListBox.ItemTemplate>
                                          <DataTemplate x:DataType="vm:ServerSummaryItem">
                                                <controls:SummaryCard Title="{Binding Name}"
                                                                                                                  Subtitle="{Binding Endpoint}"
                                                                                                                  StatusText="{Binding Status}"
                                                                                                                  AccentBrush="#7D6438"
                                                                                                                  BackgroundBrush="#362812" />
                                          </DataTemplate>
                                    </ListBox.ItemTemplate>
                              </ListBox>

                        </Grid>
                  </Border>
            </Grid>
  </Grid>
</Window>
