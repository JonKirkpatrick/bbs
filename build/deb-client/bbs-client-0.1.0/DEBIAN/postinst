#!/bin/bash
set -e

# Post-installation script for bbs-client

echo "Setting up bbs-client desktop integration..."

# Update desktop database if present
if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database /usr/share/applications 2>/dev/null || true
fi

# Update icon cache if present
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache /usr/share/icons/hicolor 2>/dev/null || true
fi

echo "bbs-client installation complete!"
echo ""
echo "You can launch bbs-client from your application menu or by running:"
echo "  bbs-client"
echo ""

exit 0
