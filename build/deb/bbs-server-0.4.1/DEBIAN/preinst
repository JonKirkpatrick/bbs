#!/bin/bash
set -e

# Pre-installation script for bbs-server
# Create system user/group if they don't exist

case "$1" in
    install|upgrade)
        # Create bbs system user if it doesn't exist
        if ! id -u bbs >/dev/null 2>&1; then
            echo "Creating bbs system user and group..."
            useradd -r -s /bin/false -d /var/lib/bbs -m bbs
        fi
        ;;
esac

exit 0
